---
// Hero. El video de fondo (hero-broll.mp4) NO se monta todavia: Ariel lo
// re-editara con Higgsfield. Cuando este listo, descomentar el <video> de
// abajo y quitar la clase de gradiente. El archivo ya esta en public/assets/video/.
---

<section class="hero" id="top">
  <!--
  Pendiente (video re-editado con Higgsfield):
  <video class="hero__video" autoplay muted loop playsinline poster="">
    <source src="/assets/video/hero-broll.mp4" type="video/mp4" />
  </video>
  -->
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="container hero__content">
    <p class="hero__eyebrow" data-reveal>Automatización · Intralogística · LATAM</p>
    <h1 class="hero__title" data-reveal style="--reveal-delay:.05s">
      Automatización e Inteligencia Logística para LATAM
    </h1>
    <p class="hero__subtitle" data-reveal style="--reveal-delay:.12s">
      Transformamos operaciones logísticas en ventajas competitivas.
    </p>
    <div class="hero__cta" data-reveal style="--reveal-delay:.2s">
      <a href="#contacto" class="btn btn-gold">Contáctanos</a>
      <a href="#soluciones" class="btn btn-outline">Ver soluciones</a>
    </div>

    <ul class="hero__stats" data-reveal style="--reveal-delay:.28s">
      <li>
        <strong>Llave en mano</strong>
        <span>Del diseño al soporte</span>
      </li>
      <li>
        <strong>Soporte local</strong>
        <span>Mismo idioma y zona horaria</span>
      </li>
      <li>
        <strong>Décadas</strong>
        <span>De experiencia internacional</span>
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 92vh, 820px);
    display: flex;
    align-items: center;
    padding-top: var(--nav-h);
    overflow: hidden;
    color: var(--white);
  }

  /* Fondo de marca (gradiente navy -> azul) mientras no haya video */
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        120% 120% at 80% 0%,
        rgba(66, 110, 154, 0.55) 0%,
        rgba(44, 44, 66, 0) 55%
      ),
      linear-gradient(135deg, var(--brand-navy-deep) 0%, var(--brand-blue-dark) 100%);
  }

  /* Patron sutil de lineas (sensacion tecnologica/industrial) */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(120% 90% at 70% 20%, #000 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(120% 90% at 70% 20%, #000 30%, transparent 80%);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 780px;
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .hero__eyebrow {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-gold);
    margin-bottom: 1.1rem;
  }

  .hero__title {
    color: var(--white);
    font-size: clamp(2.1rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.06;
    max-width: 16ch;
  }

  .hero__subtitle {
    margin-top: 1.25rem;
    font-size: clamp(1.05rem, 2.4vw, 1.4rem);
    color: #dfe3ee;
    max-width: 46ch;
  }

  .hero__cta {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__stats {
    margin-top: clamp(2.5rem, 6vw, 3.5rem);
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 5vw, 3rem);
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    padding-top: 1.75rem;
  }

  .hero__stats li {
    display: flex;
    flex-direction: column;
  }

  .hero__stats strong {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--white);
  }

  .hero__stats span {
    font-size: 0.9rem;
    color: #c2c6d4;
  }
</style>
