---
// Carrusel marquee de clientes — logos reales A COLOR, scroll infinito.
// Lista actualizada (22) con los logos entregados por el cliente (jul-2026),
// todos PNG del mismo tamaño en /assets/clientes-2/.
const clientes = [
  { src: "/assets/clientes-2/ripley.png", alt: "Ripley" },
  { src: "/assets/clientes-2/dimerc.png", alt: "Dimerc" },
  { src: "/assets/clientes-2/pf-alimentos.png", alt: "Productos Fernández" },
  { src: "/assets/clientes-2/soprole.png", alt: "Soprole" },
  { src: "/assets/clientes-2/hites.png", alt: "Hites" },
  { src: "/assets/clientes-2/belcorp.png", alt: "Belcorp" },
  { src: "/assets/clientes-2/concha-y-toro.png", alt: "Concha y Toro" },
  { src: "/assets/clientes-2/artel.png", alt: "Artel" },
  { src: "/assets/clientes-2/chilexpress.png", alt: "Chilexpress" },
  { src: "/assets/clientes-2/dimeiggs.png", alt: "Dimeiggs" },
  { src: "/assets/clientes-2/axo.png", alt: "AXO" },
  { src: "/assets/clientes-2/gino.png", alt: "Gino" },
  { src: "/assets/clientes-2/dinet.png", alt: "Dinet" },
  { src: "/assets/clientes-2/farmacias-peruanas.png", alt: "Farmacias Peruanas" },
  { src: "/assets/clientes-2/levis.png", alt: "Levi's" },
  { src: "/assets/clientes-2/flexi.png", alt: "Flexi" },
  { src: "/assets/clientes-2/flex.png", alt: "Flex" },
  { src: "/assets/clientes-2/adidas.png", alt: "adidas" },
  { src: "/assets/clientes-2/farmacorp.png", alt: "Farmacorp" },
  { src: "/assets/clientes-2/belleza-express.png", alt: "Belleza Express" },
  { src: "/assets/clientes-2/continental.png", alt: "Continental" },
  { src: "/assets/clientes-2/bosch.png", alt: "Bosch" },
];
---

<section class="clientes" aria-label="Empresas que confían en SDI Systems">
  <div class="container">
    <p class="clientes__lead">Empresas que confían en nosotros</p>
  </div>

  <div class="marquee" data-marquee>
    <ul class="marquee__track">
      {
        clientes.map((c) => (
          <li class="marquee__item">
            <img src={c.src} alt={c.alt} loading="lazy" decoding="async" />
          </li>
        ))
      }
    </ul>
    <ul class="marquee__track" aria-hidden="true">
      {
        clientes.map((c) => (
          <li class="marquee__item">
            <img src={c.src} alt="" loading="lazy" decoding="async" />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .clientes {
    padding-block: clamp(3.75rem, 6.5vw, 5.5rem);
    border-bottom: 1px solid var(--line);
    background: #f2f3f5; /* gris claro para la franja del carrusel */
  }

  .clientes__lead {
    text-align: center;
    font-family: var(--font-head);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted); /* AA sobre blanco */
    margin-bottom: clamp(2rem, 4.5vw, 3rem);
  }

  /* Pista doble para loop infinito sin costura */
  .marquee {
    display: flex;
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0,
      #000 8%,
      #000 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0,
      #000 8%,
      #000 92%,
      transparent 100%
    );
  }

  .marquee__track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: clamp(3.5rem, 7vw, 6rem);
    padding-right: clamp(3.5rem, 7vw, 6rem);
    min-width: max-content;
    /* velocidad mas visible (antes 75s se percibia casi estatico) */
    animation: marquee-scroll 45s linear infinite;
  }

  /* Pausa al hover (sobre todo el carrusel) */
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }

  .marquee__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .marquee__item img {
    height: 76px;
    width: auto;
    max-width: 260px;
    object-fit: contain;
    /* A COLOR — sin filtro grayscale */
  }

  /* Movil: logos mas contenidos y banda menos alta */
  @media (max-width: 720px) {
    .marquee__track {
      gap: clamp(2rem, 8vw, 3.25rem);
      padding-right: clamp(2rem, 8vw, 3.25rem);
    }
    .marquee__item img {
      height: 56px;
      max-width: 180px;
    }
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-100%);
    }
  }

  /* Accesibilidad: sin movimiento si el usuario lo pide */
  @media (prefers-reduced-motion: reduce) {
    .marquee {
      overflow-x: auto;
    }
    .marquee__track {
      animation: none;
    }
    /* Evita duplicado visual cuando no hay scroll automatico */
    .marquee__track[aria-hidden="true"] {
      display: none;
    }
  }
</style>
