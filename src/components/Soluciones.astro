---
// Explorador interactivo de soluciones (patron ARIA tabs).
// Copy TEXTUAL conservado del contenido original.
// Cada producto puede tener `video` (mp4 optimizado en /assets/video/equipos/);
// al seleccionarlo se reproduce en el bloque de media del panel. Si no hay video
// se muestra el placeholder (manteniendo la simetria del bloque).
const categorias = [
  {
    n: "01",
    titulo: "Clasificación Unitaria de Alta Velocidad",
    sub: "Sorters",
    items: [
      {
        nombre: "SORTRAK G4 (Bomb Bay)",
        desc: "Tecnología propia de caída vertical para clasificación masiva ultraprecisa.",
        video: "/assets/video/equipos/sortrak.mp4",
      },
      {
        nombre: "Crossbelt Sorter",
        desc: "Bandas cruzadas para paquetes, sobres, cajas y contenedores de distintos tamaños.",
        video: null,
      },
      {
        nombre: "TableSort / T-Sort + 3DSort",
        desc: "Alto volumen con pocas unidades por orden y reconfiguración rápida.",
        video: "/assets/video/equipos/tsort.mp4",
      },
    ],
  },
  {
    n: "02",
    titulo: "Clasificación de Cajas y Contenedores",
    sub: "Cajas y contenedores",
    items: [
      {
        nombre: "Narrow Belt Sorter (NBS)",
        desc: "Desvíos en múltiples configuraciones.",
        video: "/assets/video/equipos/nbs.mp4",
      },
      {
        nombre: "Shoe Sorter",
        desc: "Altas velocidades, cargas pesadas y máxima confiabilidad.",
        video: "/assets/video/equipos/shoesorter.mp4",
      },
      {
        nombre: "Crossbelt / Multibelt Sorter",
        desc: "Velocidad, precisión y aprovechamiento del espacio.",
        video: null,
      },
    ],
  },
  {
    n: "03",
    titulo: "Robóticos y Sistemas de Secuenciación",
    sub: "Robótica",
    items: [
      {
        nombre: "AutoStore™",
        desc: "Almacenamiento automatizado de mayor densidad del mercado.",
        video: "/assets/video/equipos/as.mp4",
      },
      {
        nombre: "Joey Pouch Sorter",
        desc: "Clasificador de bolsas colgantes, ideal para e-commerce.",
        video: "/assets/video/equipos/joey.mp4",
      },
      {
        nombre: "Enzo AGV",
        desc: "Vehículos de guiado automático para transporte interno autónomo.",
        video: "/assets/video/equipos/enzo.mp4",
      },
    ],
  },
  {
    n: "04",
    titulo: "Asistencia para Picking, Clasificación y Consolidación",
    sub: "Picking",
    items: [
      {
        nombre: "Pack-to-Light / Put-to-Store",
        desc: "Guiado por luz, reduce errores.",
        video: null,
      },
      {
        nombre: "PTL (Pick-to-Light)",
        desc: "Picking de alta rotación.",
        video: null,
      },
      {
        nombre: "PTW (Put-to-Wall / Put-to-Light)",
        desc: "Consolidación rápida y escalable para e-commerce.",
        video: null,
      },
    ],
  },
];
---

<section class="section section--light blueprint" id="soluciones">
  <div class="container">
    <div class="section-head section-head--center">
      <span class="eyebrow">Soluciones y Productos</span>
      <h2 class="section-title">
        Tecnología de Vanguardia para Centros de Distribución
      </h2>
      <p class="section-intro">
        Nuestro portafolio integra tecnologías líderes a nivel mundial,
        seleccionadas para responder con flexibilidad, eficiencia y
        escalabilidad a las exigencias de los mercados actuales.
      </p>
    </div>

    <div class="explorer">
      <div class="explorer__tabs" role="tablist" aria-label="Familias de soluciones" aria-orientation="vertical">
        {
          categorias.map((cat, i) => (
            <button
              class:list={["explorer__tab", { "is-active": i === 0 }]}
              role="tab"
              id={`sol-tab-${i}`}
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`sol-panel-${i}`}
              tabindex={i === 0 ? "0" : "-1"}
            >
              <span class="explorer__tab-num">{cat.n}</span>
              <span class="explorer__tab-text">
                <span class="explorer__tab-title">{cat.titulo}</span>
                <span class="explorer__tab-sub">{cat.sub}</span>
              </span>
              <svg class="explorer__tab-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 6l6 6-6 6" />
              </svg>
            </button>
          ))
        }
      </div>

      <div class="explorer__panels">
        {
          categorias.map((cat, i) => (
            <div
              class="explorer__panel"
              role="tabpanel"
              id={`sol-panel-${i}`}
              aria-labelledby={`sol-tab-${i}`}
              hidden={i !== 0}
              tabindex="0"
            >
              <div class="explorer__detail" data-explorer-detail>
                <ul class="explorer__products">
                  {cat.items.map((it, j) => (
                    <li>
                      <button
                        type="button"
                        class:list={["explorer__product", { "is-selected": j === 0 }]}
                        data-product
                        data-video={it.video ?? ""}
                        aria-pressed={j === 0 ? "true" : "false"}
                      >
                        <span class="explorer__product-name">
                          {it.nombre}
                          {it.video && (
                            <svg class="explorer__product-play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                              <path d="M8 5v14l11-7z" />
                            </svg>
                          )}
                        </span>
                        <span class="explorer__product-desc">{it.desc}</span>
                      </button>
                    </li>
                  ))}
                </ul>
                <figure class="explorer__media">
                  <video
                    class="explorer__video"
                    data-media-video
                    muted
                    loop
                    playsinline
                    preload="none"
                    hidden
                  />
                  <div class="explorer__media-ph" data-media-ph>
                    <span class="explorer__media-num">{cat.n}</span>
                    <span class="explorer__media-cap">{cat.sub}</span>
                  </div>
                </figure>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .explorer {
    display: grid;
    grid-template-columns: minmax(280px, 0.85fr) 1.4fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  /* --- Selector (tabs) --- */
  .explorer__tabs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .explorer__tab {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    text-align: left;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 1rem 1.15rem;
    cursor: pointer;
    color: var(--brand-navy);
    transition: border-color var(--t), background var(--t), box-shadow var(--t);
  }

  .explorer__tab:hover {
    border-color: var(--brand-blue);
  }

  .explorer__tab.is-active {
    background: var(--brand-navy);
    border-color: var(--brand-navy);
    box-shadow: var(--shadow);
  }

  .explorer__tab-num {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--brand-blue);
    letter-spacing: 0.05em;
  }

  .explorer__tab.is-active .explorer__tab-num {
    color: var(--brand-gold);
  }

  .explorer__tab-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }

  .explorer__tab-title {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 0.98rem;
    line-height: 1.2;
  }

  .explorer__tab-sub {
    font-size: 0.8rem;
    color: var(--muted); /* AA sobre blanco (estado inactivo) */
  }

  .explorer__tab.is-active .explorer__tab-title {
    color: var(--white);
  }

  .explorer__tab.is-active .explorer__tab-sub {
    color: #aeb2bf;
  }

  .explorer__tab-arrow {
    width: 18px;
    height: 18px;
    color: var(--brand-gray);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--t), transform var(--t);
  }

  .explorer__tab.is-active .explorer__tab-arrow {
    color: var(--brand-gold);
    opacity: 1;
    transform: translateX(0);
  }

  /* --- Panel de detalle --- */
  .explorer__panel:focus-visible {
    outline: 3px solid var(--brand-gold);
    outline-offset: 4px;
    border-radius: var(--radius);
  }

  .explorer__detail {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(1.25rem, 3vw, 2rem);
    background: var(--white);
    border: 1px solid var(--line);
    border-top: 3px solid var(--brand-blue);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    box-shadow: var(--shadow-sm);
  }

  .explorer__products {
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }

  .explorer__product {
    display: flex;
    flex-direction: column;
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    border-left: 2px solid var(--line);
    padding: 0.3rem 0.6rem 0.3rem 1rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    cursor: pointer;
    transition: border-color var(--t), background var(--t);
  }

  .explorer__product:hover {
    background: var(--bg-light);
    border-left-color: var(--brand-blue);
  }

  .explorer__product.is-selected {
    border-left-color: var(--brand-gold);
    background: var(--bg-light);
  }

  .explorer__product:focus-visible {
    outline: 3px solid var(--brand-gold);
    outline-offset: 2px;
  }

  .explorer__product-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-head);
    font-weight: 500;
    color: var(--brand-navy);
    font-size: 1rem;
  }

  .explorer__product-play {
    width: 14px;
    height: 14px;
    color: var(--brand-blue);
    flex-shrink: 0;
  }

  .explorer__product-desc {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 0.2rem;
  }

  /* Video del producto — llena el bloque de media manteniendo su alto */
  .explorer__media {
    position: relative;
  }

  .explorer__video {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 220px;
    max-height: 320px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    background: var(--brand-navy);
  }

  .explorer__video[hidden] {
    display: none;
  }

  /* Placeholder de imagen de equipo */
  .explorer__media {
    margin: 0;
  }

  .explorer__media-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    height: 100%;
    min-height: 220px;
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, var(--brand-navy), var(--brand-navy-deep));
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .explorer__media-ph::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
  }

  .explorer__media-num {
    position: relative;
    font-family: var(--font-head);
    font-size: 2.6rem;
    font-weight: 700;
    color: var(--brand-gold);
    line-height: 1;
  }

  .explorer__media-cap {
    position: relative;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #c8cbd4;
  }

  @media (max-width: 860px) {
    .explorer {
      grid-template-columns: 1fr;
    }
    .explorer__tab-arrow {
      display: none;
    }
    .explorer__detail {
      grid-template-columns: 1fr;
    }
    .explorer__media {
      order: -1;
    }
    .explorer__media-ph {
      min-height: 150px;
    }
  }
</style>

<script>
  // Patron ARIA tabs con tabindex itinerante (roving) + flechas/Home/End.
  // Ademas: al seleccionar un producto se reproduce su video en el bloque de
  // media del panel (sin cambiar de pestaña). Sin video -> placeholder.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll<HTMLElement>("#soluciones .explorer").forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[role="tabpanel"]'));

    function applyMedia(panel: HTMLElement, play: boolean) {
      const video = panel.querySelector<HTMLVideoElement>("[data-media-video]");
      const ph = panel.querySelector<HTMLElement>("[data-media-ph]");
      const products = Array.from(panel.querySelectorAll<HTMLButtonElement>("[data-product]"));
      const sel = products.find((p) => p.classList.contains("is-selected")) || products[0];
      const src = sel?.getAttribute("data-video") || "";
      if (src && video) {
        if (video.getAttribute("src") !== src) video.setAttribute("src", src);
        video.hidden = false;
        if (ph) ph.style.display = "none";
        if (play) video.play().catch(() => {});
      } else {
        if (video) {
          video.pause();
          video.hidden = true;
        }
        if (ph) ph.style.display = "";
      }
    }

    // Click en producto -> selecciona y reproduce su video
    panels.forEach((panel) => {
      const products = Array.from(panel.querySelectorAll<HTMLButtonElement>("[data-product]"));
      products.forEach((btn) => {
        btn.addEventListener("click", () => {
          products.forEach((p) => {
            const on = p === btn;
            p.classList.toggle("is-selected", on);
            p.setAttribute("aria-pressed", String(on));
          });
          applyMedia(panel, true);
        });
      });
    });

    function select(index: number, setFocus = true) {
      tabs.forEach((tab, i) => {
        const active = i === index;
        tab.setAttribute("aria-selected", String(active));
        tab.tabIndex = active ? 0 : -1;
        tab.classList.toggle("is-active", active);
        panels[i].hidden = !active;
        if (!active) panels[i].querySelector<HTMLVideoElement>("[data-media-video]")?.pause();
      });
      applyMedia(panels[index], !reduce);
      if (setFocus) tabs[index].focus();
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i, false));
      tab.addEventListener("keydown", (e) => {
        let next = -1;
        if (e.key === "ArrowDown" || e.key === "ArrowRight") next = (i + 1) % tabs.length;
        else if (e.key === "ArrowUp" || e.key === "ArrowLeft") next = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === "Home") next = 0;
        else if (e.key === "End") next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          select(next);
        }
      });
    });

    // Estado inicial: el panel visible muestra (y reproduce) su video seleccionado
    applyMedia(panels[0], !reduce);
  });
</script>
