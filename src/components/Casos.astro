---
// Casos de exito — formato problema -> solucion -> resultado, con metricas.
// El muro de clientes se movio al carrusel (Clientes.astro), aqui van solo casos.
// Atribucion fresco/congelado + transelevador 740 = PF Alimentos (segun fuente).
// NOTA: las metricas marcadas "(placeholder)" deben confirmarse con Ariel.
const casos = [
  {
    cliente: "Dimerc",
    logo: "/assets/clientes-2/dimerc.png",
    foto: "/assets/img/casos/dimerc-picking-unidades.png",
    video: "/assets/video/casos/dimerc.mp4",
    problema:
      "Surtido mixto de cajas y unidades hacia tiendas, con alta exigencia de precisión y volumen.",
    solucion:
      "Picking de cajas (torres de picking, pick-to-pallet, sorter a tiendas) y picking de unidades (pick-to-light, RF, balanza de validación).",
    resultado: "Operación de picking mixta, más rápida y con menos errores.",
    metricas: [
      { valor: "+25%", label: "líneas por hora", ph: true },
      { valor: "−30%", label: "errores de picking", ph: true },
    ],
  },
  {
    cliente: "Soprole",
    logo: "/assets/clientes-2/soprole.png",
    foto: "/assets/img/casos/soprole-picking.jpg",
    video: null,
    problema:
      "Reposición a tiendas con alto volumen y necesidad de estandarizar el picking.",
    solucion:
      "Picking de cajas (pick-to-belt, sorter a tiendas) y picking de unidades (pick-to-light).",
    resultado: "Despacho a tiendas más ágil y estandarizado.",
    metricas: [
      { valor: "+30%", label: "productividad", ph: true },
      { valor: "2x", label: "velocidad de despacho", ph: true },
    ],
  },
  {
    cliente: "PF Alimentos",
    logo: "/assets/clientes-2/pf-alimentos.png",
    foto: "/assets/img/casos/pf-alimentos-layout.png",
    video: null,
    problema:
      "Operación con cadena de frío (0–4°), congelado (−28°) y manejo de pallets.",
    solucion:
      "5 torres de picking, sorter a rutas, sistemas para fresco (0–4°) y congelado (−28°), y transelevador de 740 posiciones (pallets).",
    resultado: "Centro de distribución con fresco, congelado y pallets integrados.",
    metricas: [
      { valor: "740", label: "posiciones de transelevador", ph: false },
      { valor: "−28°C", label: "operación en congelado", ph: false },
    ],
  },
];
---

<section class="section blueprint" id="casos">
  <div class="container">
    <div class="section-head section-head--center">
      <span class="eyebrow">Casos de Éxito</span>
      <h2 class="section-title">Proyectos reales, resultados en operación</h2>
      <p class="section-intro">
        Proyectos implementados en centros de distribución de Chile y LATAM, del
        problema operativo al resultado en planta.
      </p>
    </div>

    <div class="casos">
      {
        casos.map((caso, i) => (
          <article class="caso" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <div class="caso__media">
              {caso.video ? (
                <button
                  type="button"
                  class="caso__play"
                  data-caso-video={caso.video}
                  data-caso-title={caso.cliente}
                  aria-label={`Ver video del proyecto en ${caso.cliente}`}
                >
                  <img
                    src={caso.foto}
                    alt={`Proyecto SDI Systems en ${caso.cliente}`}
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="caso__play-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                  </span>
                </button>
              ) : (
                <img
                  src={caso.foto}
                  alt={`Proyecto SDI Systems en ${caso.cliente}`}
                  loading="lazy"
                  decoding="async"
                />
              )}
            </div>

            <div class="caso__body">
              <div class="caso__head">
                <img class="caso__logo" src={caso.logo} alt={caso.cliente} loading="lazy" />
              </div>

              <dl class="caso__flow">
                <div class="caso__step">
                  <dt class="caso__label">Problema</dt>
                  <dd>{caso.problema}</dd>
                </div>
                <div class="caso__step">
                  <dt class="caso__label caso__label--sol">Solución SDI</dt>
                  <dd>{caso.solucion}</dd>
                </div>
                <div class="caso__step">
                  <dt class="caso__label caso__label--res">Resultado</dt>
                  <dd>{caso.resultado}</dd>
                </div>
              </dl>

              <ul class="caso__metrics">
                {caso.metricas.map((m) => (
                  <li class="caso__metric">
                    <span class="caso__metric-num">{m.valor}</span>
                    <span class="caso__metric-label">{m.label}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <div class="caso-modal" data-caso-modal hidden>
    <div class="caso-modal__backdrop" data-caso-close></div>
    <div class="caso-modal__dialog" role="dialog" aria-modal="true" aria-label="Video del proyecto">
      <button type="button" class="caso-modal__close" data-caso-close aria-label="Cerrar video">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </button>
      <video class="caso-modal__video" data-caso-modal-video controls playsinline preload="none"></video>
    </div>
  </div>
</section>

<style>
  .casos {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  .caso {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  /* Alterna el lado de la imagen para dar ritmo */
  .caso:nth-child(even) .caso__media {
    order: 2;
  }

  .caso__media {
    align-self: stretch;
    min-height: 280px;
    background: var(--brand-navy);
    overflow: hidden;
  }

  .caso__media img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
  }

  .caso__body {
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .caso__head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .caso__logo {
    height: 44px;
    width: auto;
    max-width: 170px;
    object-fit: contain;
    object-position: left;
  }

  /* Media clickable con boton de play (casos con video) */
  .caso__play {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: var(--brand-navy);
    cursor: pointer;
  }

  .caso__play img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    transition: transform var(--t), opacity var(--t);
  }

  .caso__play:hover img {
    transform: scale(1.03);
    opacity: 0.92;
  }

  .caso__play-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(222, 171, 36, 0.92);
    color: var(--brand-navy);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    transition: transform var(--t);
  }

  .caso__play:hover .caso__play-icon {
    transform: scale(1.08);
  }

  .caso__play-icon svg {
    width: 30px;
    height: 30px;
    margin-left: 3px;
  }

  .caso__play:focus-visible {
    outline: 3px solid var(--brand-gold);
    outline-offset: 3px;
  }

  /* Modal de video */
  .caso-modal[hidden] {
    display: none;
  }

  .caso-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
  }

  .caso-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(11, 16, 32, 0.86);
    backdrop-filter: blur(4px);
  }

  .caso-modal__dialog {
    position: relative;
    width: min(1000px, 100%);
    aspect-ratio: 16 / 9;
    max-height: 86vh;
    background: #000;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.5);
    animation: caso-modal-in 0.24s ease;
  }

  @keyframes caso-modal-in {
    from { transform: scale(0.96); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .caso-modal__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000;
  }

  .caso-modal__close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: var(--brand-navy);
    cursor: pointer;
    transition: background var(--t), transform var(--t);
  }

  .caso-modal__close:hover {
    background: #fff;
    transform: scale(1.05);
  }

  .caso-modal__close svg {
    width: 22px;
    height: 22px;
  }

  .caso__flow {
    display: grid;
    gap: 1.1rem;
  }

  .caso__step {
    padding-left: 1rem;
    border-left: 2px solid var(--line);
  }

  .caso__step dd {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .caso__label {
    display: block;
    font-family: var(--font-head);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted); /* AA sobre blanco */
    margin-bottom: 0.3rem;
  }

  .caso__label--sol {
    color: var(--brand-blue);
  }

  .caso__label--res {
    color: var(--brand-navy); /* AA sobre blanco (el dorado falla en texto pequeño) */
  }

  .caso__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .caso__metric-num {
    display: block;
    font-family: var(--font-head);
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1;
    color: var(--brand-navy);
  }

  .caso__metric-label {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.82rem;
    color: var(--muted); /* AA sobre blanco */
    max-width: 16ch;
  }

  @media (max-width: 820px) {
    .caso {
      grid-template-columns: 1fr;
    }
    .caso:nth-child(even) .caso__media {
      order: 0;
    }
    .caso__media,
    .caso__media img,
    .caso__play img {
      min-height: 220px;
      max-height: 300px;
    }
  }
</style>

<script>
  // Modal de video para casos con video (imagen -> se agranda en pantalla).
  const modal = document.querySelector<HTMLElement>("[data-caso-modal]");
  const video = modal?.querySelector<HTMLVideoElement>("[data-caso-modal-video]");

  if (modal && video) {
    let lastTrigger: HTMLElement | null = null;

    function open(src: string, trigger: HTMLElement) {
      lastTrigger = trigger;
      video.setAttribute("src", src);
      modal.hidden = false;
      document.body.style.overflow = "hidden";
      video.currentTime = 0;
      video.play().catch(() => {});
      modal.querySelector<HTMLButtonElement>("[data-caso-close]")?.focus();
    }

    function close() {
      video.pause();
      video.removeAttribute("src");
      video.load();
      modal.hidden = true;
      document.body.style.overflow = "";
      lastTrigger?.focus();
    }

    document.querySelectorAll<HTMLButtonElement>("[data-caso-video]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = btn.getAttribute("data-caso-video");
        if (src) open(src, btn);
      });
    });

    modal.querySelectorAll<HTMLElement>("[data-caso-close]").forEach((el) =>
      el.addEventListener("click", close),
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.hidden) close();
    });
  }
</script>
